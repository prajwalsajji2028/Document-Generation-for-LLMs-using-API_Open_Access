{
  "name": "docxforge",
  "version": "1.0.0",
  "description": "API-first document generation service — converts JSON/Markdown to professionally formatted .docx files",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "node src/queue/worker.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/cors": "^9.0.1",
    "docx": "^8.5.0",
    "zod": "^3.23.0",
    "bullmq": "^5.8.0",
    "ioredis": "^5.4.0",
    "marked": "^12.0.0",
    "uuid": "^9.0.1",
    "pino": "^9.1.0",
    "pino-pretty": "^11.2.0"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  },
  "keywords": ["docx", "document-generation", "api", "markdown", "pdf"],
  "license": "MIT"
}
